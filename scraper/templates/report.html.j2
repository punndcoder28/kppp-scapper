<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Karnataka Tenders — {{ run_date }}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f7fa; color: #1a1a2e; }
    .header { background: linear-gradient(135deg, #1a237e, #283593); color: white; padding: 2rem; }
    .header h1 { font-size: 1.6rem; font-weight: 700; margin-bottom: 0.5rem; }
    .meta { display: flex; flex-wrap: wrap; gap: 1.5rem; margin-top: 1rem; }
    .meta-item { font-size: 0.85rem; opacity: 0.85; }
    .meta-item strong { opacity: 1; }
    .pills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
    .pill { padding: 0.3rem 0.8rem; border-radius: 999px; font-size: 0.78rem; font-weight: 600; }
    .pill-lab { background: #e8f5e9; color: #1b5e20; }
    .pill-construction { background: #fff3e0; color: #bf360c; }
    .pill-other { background: #e3f2fd; color: #0d47a1; }
    .pill-low { background: #f3e5f5; color: #4a148c; }
    .container { max-width: 1200px; margin: 2rem auto; padding: 0 1rem; }
    .section { margin-bottom: 2.5rem; }
    .section-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid; }
    .section-lab .section-header { border-color: #2e7d32; }
    .section-construction .section-header { border-color: #e65100; }
    .section-other .section-header { border-color: #1565c0; }
    .section-low .section-header { border-color: #6a1b9a; }
    .section-title { font-size: 1.15rem; font-weight: 700; }
    .section-lab .section-title { color: #2e7d32; }
    .section-construction .section-title { color: #e65100; }
    .section-other .section-title { color: #1565c0; }
    .section-low .section-title { color: #6a1b9a; }
    .badge { font-size: 0.75rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 4px; }
    .badge-lab { background: #c8e6c9; color: #1b5e20; }
    .badge-construction { background: #ffe0b2; color: #bf360c; }
    .badge-other { background: #bbdefb; color: #0d47a1; }
    .badge-low { background: #e1bee7; color: #4a148c; }
    .empty-state { color: #666; font-style: italic; padding: 1rem 0; }
    table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
    thead { background: #f8f9fa; }
    th { padding: 0.75rem 1rem; text-align: left; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #555; white-space: nowrap; }
    td { padding: 0.75rem 1rem; font-size: 0.88rem; border-top: 1px solid #f0f0f0; vertical-align: top; }
    tr:hover td { background: #fafafa; }
    .ecv { font-weight: 600; white-space: nowrap; }
    .ecv-known { color: #1b5e20; }
    .ecv-unknown { color: #999; font-style: italic; }
    .deadline { white-space: nowrap; }
    .tender-no { font-family: monospace; font-size: 0.8rem; color: #555; }
    .title-cell { max-width: 320px; }
    .dept-cell { max-width: 200px; color: #444; }
    .reason { font-size: 0.75rem; color: #888; font-style: italic; margin-top: 0.2rem; }
    a { color: #1565c0; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .low-section details summary { cursor: pointer; color: #6a1b9a; font-size: 0.9rem; padding: 0.5rem 0; }
    .footer { text-align: center; padding: 2rem; color: #888; font-size: 0.8rem; border-top: 1px solid #e0e0e0; margin-top: 2rem; }
  </style>
</head>
<body>

<div class="header">
  <div style="margin-bottom:0.75rem"><a href="../index.html" style="color:rgba(255,255,255,0.75);font-size:0.85rem;text-decoration:none;">← All Reports</a></div>
  <h1>Karnataka Government Tenders</h1>
  <div class="meta">
    <div class="meta-item">Date: <strong>{{ run_date }}</strong></div>
    <div class="meta-item">Total scraped: <strong>{{ total }}</strong></div>
    <div class="meta-item">Source: <strong>{{ source }}</strong></div>
    <div class="meta-item">Generated: <strong>{{ generated_at }}</strong></div>
  </div>
  <div class="pills">
    <span class="pill pill-lab">{{ counts.lab_equipment }} Lab Equipment</span>
    <span class="pill pill-construction">{{ counts.construction }} Construction</span>
    <span class="pill pill-other">{{ counts.other_supply }} Other Supply</span>
    <span class="pill pill-low">{{ counts.low_priority }} Low Priority</span>
  </div>
</div>

<div class="container">

  {# ── Lab Equipment ── #}
  <div class="section section-lab">
    <div class="section-header">
      <span class="section-title">Lab Equipment Tenders</span>
      <span class="badge badge-lab">{{ sections.lab_equipment | length }}</span>
    </div>
    {% if sections.lab_equipment %}
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Department</th>
          <th>ECV</th>
          <th>Deadline</th>
          <th>Tender No.</th>
          <th>Link</th>
        </tr>
      </thead>
      <tbody>
        {% for t in sections.lab_equipment %}
        <tr>
          <td class="title-cell">
            {{ t.title or "—" }}
            {% if t._reason %}<div class="reason">{{ t._reason }}</div>{% endif %}
          </td>
          <td class="dept-cell">{{ t.department or "—" }}</td>
          <td class="ecv {% if t.ecv %}ecv-known{% else %}ecv-unknown{% endif %}">
            {{ format_ecv(t.ecv) }}
          </td>
          <td class="deadline">{{ t.deadline or "—" }}</td>
          <td class="tender-no">{{ t.tender_number or "—" }}</td>
          <td>
            {% if t.nit_url %}<a href="{{ t.nit_url }}" target="_blank">View</a>{% else %}—{% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p class="empty-state">No lab equipment tenders found this run.</p>
    {% endif %}
  </div>

  {# ── Construction ── #}
  <div class="section section-construction">
    <div class="section-header">
      <span class="section-title">Construction Tenders</span>
      <span class="badge badge-construction">{{ sections.construction | length }}</span>
    </div>
    {% if sections.construction %}
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Department</th>
          <th>ECV</th>
          <th>Deadline</th>
          <th>Tender No.</th>
          <th>Link</th>
        </tr>
      </thead>
      <tbody>
        {% for t in sections.construction %}
        <tr>
          <td class="title-cell">
            {{ t.title or "—" }}
            {% if t._reason %}<div class="reason">{{ t._reason }}</div>{% endif %}
          </td>
          <td class="dept-cell">{{ t.department or "—" }}</td>
          <td class="ecv {% if t.ecv %}ecv-known{% else %}ecv-unknown{% endif %}">
            {{ format_ecv(t.ecv) }}
          </td>
          <td class="deadline">{{ t.deadline or "—" }}</td>
          <td class="tender-no">{{ t.tender_number or "—" }}</td>
          <td>
            {% if t.nit_url %}<a href="{{ t.nit_url }}" target="_blank">View</a>{% else %}—{% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p class="empty-state">No construction tenders found this run.</p>
    {% endif %}
  </div>

  {# ── Other Supply ── #}
  <div class="section section-other">
    <div class="section-header">
      <span class="section-title">Other Supply Tenders</span>
      <span class="badge badge-other">{{ sections.other_supply | length }}</span>
    </div>
    {% if sections.other_supply %}
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Department</th>
          <th>ECV</th>
          <th>Deadline</th>
          <th>Tender No.</th>
          <th>Link</th>
        </tr>
      </thead>
      <tbody>
        {% for t in sections.other_supply %}
        <tr>
          <td class="title-cell">
            {{ t.title or "—" }}
            {% if t._reason %}<div class="reason">{{ t._reason }}</div>{% endif %}
          </td>
          <td class="dept-cell">{{ t.department or "—" }}</td>
          <td class="ecv {% if t.ecv %}ecv-known{% else %}ecv-unknown{% endif %}">
            {{ format_ecv(t.ecv) }}
          </td>
          <td class="deadline">{{ t.deadline or "—" }}</td>
          <td class="tender-no">{{ t.tender_number or "—" }}</td>
          <td>
            {% if t.nit_url %}<a href="{{ t.nit_url }}" target="_blank">View</a>{% else %}—{% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p class="empty-state">No other supply tenders found this run.</p>
    {% endif %}
  </div>

  {# ── Low Priority (collapsible) ── #}
  {% if sections.low_priority %}
  <div class="section section-low low-section">
    <details>
      <summary>
        <strong>Low Priority</strong> (IT equipment, stationery) —
        {{ sections.low_priority | length }} tenders
      </summary>
      <br>
      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Department</th>
            <th>ECV</th>
            <th>Deadline</th>
            <th>Tender No.</th>
            <th>Link</th>
          </tr>
        </thead>
        <tbody>
          {% for t in sections.low_priority %}
          <tr>
            <td class="title-cell">
              {{ t.title or "—" }}
              {% if t._reason %}<div class="reason">{{ t._reason }}</div>{% endif %}
            </td>
            <td class="dept-cell">{{ t.department or "—" }}</td>
            <td class="ecv {% if t.ecv %}ecv-known{% else %}ecv-unknown{% endif %}">
              {{ format_ecv(t.ecv) }}
            </td>
            <td class="deadline">{{ t.deadline or "—" }}</td>
            <td class="tender-no">{{ t.tender_number or "—" }}</td>
            <td>
              {% if t.nit_url %}<a href="{{ t.nit_url }}" target="_blank">View</a>{% else %}—{% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </details>
  </div>
  {% endif %}

</div>

<div class="footer">
  Classification by Claude AI ({{ "claude-haiku-4-5" }}) &mdash; manual review recommended before applying.
  &nbsp;|&nbsp; Portal: <a href="https://kppp.karnataka.gov.in/#/portal/searchTender/live" target="_blank">kppp.karnataka.gov.in</a>
</div>

</body>
</html>
